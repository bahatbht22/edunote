<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'EduNote' %></title>
  <meta name="description" content="Free educational notes for Rwanda students — O'Level, A'Level, and TVET">
  <link rel="stylesheet" href="/css/public.css">
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📚</text></svg>">
  <%- typeof style !== 'undefined' ? style : '' %>
</head>
<body>
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/" class="navbar-brand">
        📚 Edu<span class="brand-dot">Note</span>
      </a>
      <ul class="navbar-links">
        <li><a href="/" class="<%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'active' : '' %>">Home</a></li>
        <li><a href="/browse" class="<%= typeof currentPage !== 'undefined' && currentPage === 'browse' ? 'active' : '' %>">Browse Notes</a></li>
        <li><a href="/browse" class="btn-nav">Get Notes</a></li>
      </ul>
      <button class="navbar-hamburger" id="hamburger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="navbar-mobile" id="mobileNav">
      <a href="/">Home</a>
      <a href="/browse">Browse Notes</a>
      <a href="/browse" class="btn-nav-mobile">Get Notes</a>
    </div>
  </nav>

  <% if (locals.success && success.length > 0) { %>
    <div class="flash-wrap"><div class="flash flash-success">✓ <%= success[0] %></div></div>
  <% } %>
  <% if (locals.error && error.length > 0) { %>
    <div class="flash-wrap"><div class="flash flash-error">⚠ <%= error[0] %></div></div>
  <% } %>

  <%- body %>

  <footer class="footer">
    <p>© <%= new Date().getFullYear() %> EduNote &mdash; Free educational notes for Rwanda students &mdash;
      <a href="/admin/login">Admin</a>
    </p>
  </footer>

  <script src="/js/public.js"></script>
  <%- typeof script !== 'undefined' ? script : '' %>
</body>
</html>
