<section class="page-header">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/notes">Levels</a>
      <span class="bc-sep">›</span>
      <a href="/notes/<%= level.slug %>"><%= level.name %></a>
      <span class="bc-sep">›</span>
      <span><%= combo.name %></span>
    </nav>
    <div style="display:flex;align-items:center;gap:1.25rem;margin-top:.5rem">
      <div style="width:56px;height:56px;border-radius:16px;background:<%= combo.color %>;display:flex;align-items:center;justify-content:center;color:white;font-size:1.75rem;font-weight:800;flex-shrink:0">
        <%= combo.name.charAt(0) %>
      </div>
      <div>
        <h1><%= combo.name %><% if(combo.full_name){ %> <span style="font-weight:400;font-size:1.5rem">— <%= combo.full_name %></span><% } %></h1>
        <p style="color:rgba(255,255,255,.55);margin-top:.25rem"><%= level.name %> — Choose your class year</p>
      </div>
    </div>
  </div>
</section>

<!-- Combination switcher tabs -->
<% if (allCombos && allCombos.length > 1) { %>
<div class="level-tabs-bar">
  <div class="container">
    <div class="level-tabs">
      <span class="level-tabs-label">Combination:</span>
      <div style="display:flex">
        <% allCombos.forEach(c => { %>
          <a href="/notes/<%= level.slug %>/<%= c.slug %>"
             class="level-tab <%= c.id === combo.id ? 'active' : '' %>"
             style="--tc: <%= c.color %>">
            <%= c.name %>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
</div>
<% } %>

<section class="level-picker">
  <div class="container">
    <% if (classes.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">📚</div>
        <h3>No classes yet</h3>
        <p>No classes have been added for <strong><%= combo.name %></strong> yet.</p>
        <a href="/notes/<%= level.slug %>" class="btn btn-outline" style="margin-top:1.5rem">← Back to combinations</a>
      </div>
    <% } else { %>
      <div style="max-width:700px;margin:0 auto">
        <p class="result-count" style="text-align:center;margin-bottom:2rem">
          <strong><%= classes.length %></strong> class<%= classes.length !== 1 ? 'es' : '' %> in <%= combo.name %>
        </p>
        <div class="level-picker-grid">
          <% classes.forEach(cls => { %>
            <a href="/notes/<%= level.slug %>/<%= combo.slug %>/<%= cls.slug %>" class="level-card" style="--lc: <%= combo.color %>">
              <div class="lc-left">
                <div class="lc-icon" style="background:<%= combo.color %>"><%= cls.name %></div>
                <div class="lc-info">
                  <h3><%= cls.name %></h3>
                  <p><%= cls.note_count || 0 %> note<%= (cls.note_count||0) !== 1 ? 's' : '' %> available</p>
                </div>
              </div>
              <div class="lc-right">
                <span class="lc-count"><%= cls.note_count || 0 %> notes</span>
                <span class="lc-arrow">
                  <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</section>
