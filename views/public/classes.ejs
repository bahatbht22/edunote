<section class="page-hero">
  <div class="page-hero-inner">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/browse">Browse</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/browse/<%= level.slug %>"><%= level.name %></a>
      <span class="breadcrumb-sep">›</span>
      <span class="current"><%= combo.name %></span>
    </div>
    <div class="page-hero-badge" style="background: color-mix(in srgb, <%= combo.color %> 25%, transparent); border: 1px solid color-mix(in srgb, <%= combo.color %> 40%, transparent)">
      <span style="font-weight:700"><%= combo.name %></span>
    </div>
    <h1 class="page-hero-title">Choose Your Class</h1>
    <p class="page-hero-desc">Select your class to access all available notes.</p>
  </div>
</section>

<section class="section">
  <div class="section-inner" style="--combo-color: <%= combo.color %>">
    <% if (classes.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">📭</div>
        <h3>No classes yet</h3>
        <p>Classes will be added for <%= combo.name %> soon.</p>
      </div>
    <% } else { %>
      <div class="class-list">
        <% classes.forEach(cls => { %>
          <a href="/browse/<%= level.slug %>/<%= combo.slug %>/<%= cls.slug %>" class="class-item" style="--combo-color: <%= combo.color %>">
            <div class="class-item-left">
              <div class="class-badge"><%= cls.name %></div>
              <div>
                <div class="class-name"><%= combo.name %> — <%= cls.name %></div>
                <div class="class-count"><%= cls.note_count || 0 %> notes available</div>
              </div>
            </div>
            <div class="class-arrow">→</div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
