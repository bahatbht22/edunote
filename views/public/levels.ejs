<section class="page-header">
  <div class="container">
    <a href="/" class="back-link">← Back to Home</a>
    <h1>Browse <em>Notes</em></h1>
    <p>Select your education level to find combinations and notes</p>
  </div>
</section>
<section class="sectors-page">
  <div class="container">
    <% if (levels.length === 0) { %>
      <div class="empty-state"><div class="empty-icon">📚</div><h3>No content yet</h3><p>Check back soon!</p></div>
    <% } else { %>
      <p class="result-count"><strong><%= levels.length %></strong> education level<%= levels.length !== 1 ? 's' : '' %> available</p>
      <div class="subjects-grid">
        <% levels.forEach(level => { %>
          <a href="/notes/<%= level.slug %>" class="subject-card" style="--sc: <%= level.color %>">
            <div class="subject-card-top">
              <div class="subject-icon"><span><%= level.icon %></span></div>
            </div>
            <h3 class="subject-name"><%= level.name %></h3>
            <p class="subject-desc"><%= level.description || 'Browse combinations and notes for this level.' %></p>
            <div class="subject-footer">
              <span class="subject-cta">Browse <svg class="subject-arrow" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
</section>
