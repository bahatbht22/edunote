<section class="page-header">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/notes">Levels</a>
      <span class="bc-sep">›</span>
      <span><%= level.name %></span>
    </nav>
    <div style="display:flex;align-items:center;gap:1.25rem;margin-top:.5rem">
      <div style="width:56px;height:56px;border-radius:16px;background:rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:1.75rem;flex-shrink:0"><%= level.icon %></div>
      <div>
        <h1><%= level.name %></h1>
        <p style="color:rgba(255,255,255,.55);margin-top:.25rem"><%= level.description || 'Choose your combination below' %></p>
      </div>
    </div>
  </div>
</section>
<section class="level-picker">
  <div class="container">
    <% if (combinations.length === 0) { %>
      <div class="empty-state"><div class="empty-icon">📄</div><h3>No combinations yet</h3><p>Content is being added for this level.</p></div>
    <% } else { %>
      <div style="max-width:800px;margin:0 auto">
        <p class="result-count" style="text-align:center;margin-bottom:2rem"><strong><%= combinations.length %></strong> combination<%= combinations.length !== 1 ? 's' : '' %> in <%= level.name %></p>
        <div class="level-picker-grid">
          <% combinations.forEach(combo => { %>
            <a href="/notes/<%= level.slug %>/<%= combo.slug %>" class="level-card" style="--lc: <%= combo.color %>">
              <div class="lc-left">
                <div class="lc-icon" style="background:<%= combo.color %>"><%= combo.name.charAt(0) %></div>
                <div class="lc-info">
                  <h3><%= combo.name %><% if(combo.full_name){ %> — <span style="font-weight:400;font-size:.9rem"><%= combo.full_name %></span><% } %></h3>
                  <% if(combo.description){ %><p><%= combo.description %></p><% } %>
                </div>
              </div>
              <div class="lc-right">
                <span class="lc-count"><%= combo.class_count || 0 %> class<%= (combo.class_count||0) !== 1 ? 'es' : '' %></span>
                <span class="lc-arrow">
                  <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>
</section>
