<div class="admin-page-header">
  <div>
    <h1>Add Education Level</h1>
    <div class="admin-breadcrumb">
      <a href="/admin/levels">Levels</a> › Add Level
    </div>
  </div>
</div>

<div class="card" style="max-width:700px">
  <div class="card-body">
    <form action="/admin/levels" method="POST">
      <div class="form-grid">
        <div class="form-group full">
          <label>Level Name <span class="req">*</span></label>
          <input type="text" name="name" placeholder="e.g. O'Level (Ordinary Level)" required>
          <span class="form-hint">e.g. O'Level, A'Level, TVET</span>
        </div>
        <div class="form-group full">
          <label>Description</label>
          <textarea name="description" placeholder="Brief description of this education level..."></textarea>
        </div>
        <div class="form-group">
          <label>Color</label>
          <input type="color" name="color" value="#4f46e5">
          <span class="form-hint">Used for visual accents</span>
        </div>
        <div class="form-group">
          <label>Display Order</label>
          <input type="number" name="order_index" value="0" min="0">
          <span class="form-hint">Lower numbers appear first</span>
        </div>
      </div>
      <div style="display:flex;gap:1rem;margin-top:1.5rem">
        <button type="submit" class="btn btn-primary btn-lg">Create Level</button>
        <a href="/admin/levels" class="btn btn-secondary btn-lg">Cancel</a>
      </div>
    </form>
  </div>
</div>
