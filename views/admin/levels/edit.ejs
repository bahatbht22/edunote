<div class="admin-page-header">
  <div>
    <h1>Edit Level</h1>
    <div class="admin-breadcrumb"><a href="/admin/levels">Levels</a> › Edit</div>
  </div>
</div>
<div class="card" style="max-width:700px">
  <div class="card-body">
    <form action="/admin/levels/<%= level.id %>" method="POST">
      <div class="form-grid">
        <div class="form-group full">
          <label>Level Name <span class="req">*</span></label>
          <input type="text" name="name" value="<%= level.name %>" required>
        </div>
        <div class="form-group full">
          <label>Description</label>
          <textarea name="description"><%= level.description %></textarea>
        </div>
        <div class="form-group">
          <label>Color</label>
          <input type="color" name="color" value="<%= level.color %>">
        </div>
        <div class="form-group">
          <label>Display Order</label>
          <input type="number" name="order_index" value="<%= level.order_index %>">
        </div>
      </div>
      <div style="display:flex;gap:1rem;margin-top:1.5rem">
        <button type="submit" class="btn btn-primary btn-lg">Save Changes</button>
        <a href="/admin/levels" class="btn btn-secondary btn-lg">Cancel</a>
      </div>
    </form>
  </div>
</div>
