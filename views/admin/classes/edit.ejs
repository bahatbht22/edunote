<div class="admin-page-header">
  <div>
    <h1>Edit Class</h1>
    <div class="admin-breadcrumb">
      <a href="<%= typeof session !== 'undefined' && session.adminRole === 'sub' ? '/admin/levels/' + session.adminLevelId + '/combinations' : '/admin/levels' %>">Levels</a> ›
      <a href="/admin/levels/<%= level.id %>/combinations"><%= level.name %></a> ›
      <a href="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>/classes"><%= combo.name %></a> ›
      Edit
    </div>
  </div>
</div>
<div class="card" style="max-width:500px">
  <div class="card-body">
    <form action="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>/classes/<%= cls.id %>" method="POST">
      <div class="form-grid">
        <div class="form-group full">
          <label>Class Name <span class="req">*</span></label>
          <input type="text" name="name" value="<%= cls.name %>" required>
        </div>
        <div class="form-group">
          <label>Display Order</label>
          <input type="number" name="order_index" value="<%= cls.order_index %>">
        </div>
      </div>
      <div style="display:flex;gap:1rem;margin-top:1.5rem">
        <button type="submit" class="btn btn-primary btn-lg">Save Changes</button>
        <a href="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>/classes" class="btn btn-secondary btn-lg">Cancel</a>
      </div>
    </form>
  </div>
</div>
