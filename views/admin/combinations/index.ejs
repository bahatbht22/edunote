<div class="admin-page-header">
  <div>
    <h1 class="admin-page-title"><%= level.name %> — Combinations</h1>
    <div class="admin-breadcrumb">
      <% if (typeof isSuper !== 'undefined' && isSuper) { %>
        <a href="/admin/levels">All Levels</a> ›
      <% } %>
      <span class="current"><%= level.name %></span>
    </div>
  </div>
  <a href="/admin/levels/<%= level.id %>/combinations/create" class="btn-primary">
    <%= typeof isSuper !== 'undefined' && !isSuper ? '+ Request New Combination' : '+ Add Combination' %>
  </a>
</div>

<% const msgs = typeof success !== 'undefined' || typeof error !== 'undefined' ? true : false; %>
<% if (typeof success !== 'undefined' && success && success.length) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
<% if (typeof error !== 'undefined' && error && error.length) { %><div class="alert alert-error"><%= error[0] %></div><% } %>

<!-- Sub-admin: show their pending requests -->
<% if (typeof isSuper !== 'undefined' && !isSuper && typeof myRequests !== 'undefined' && myRequests.length > 0) { %>
<div class="info-box" style="margin-bottom:1.5rem">
  <div style="font-weight:700;margin-bottom:.5rem">⏳ Your Pending Requests (<%= myRequests.filter(r=>r.status==='pending').length %>)</div>
  <% myRequests.filter(r=>r.status==='pending').forEach(r => { %>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:.5rem 0;border-bottom:1px solid #fde68a;font-size:.875rem">
      <span>
        <% if(r.request_type==='create') { %>➕ New combination request<% } %>
        <% if(r.request_type==='edit') { %>✏️ Edit request for <strong><%= r.combo_name %></strong><% } %>
        <% if(r.request_type==='delete') { %>🗑 Delete request for <strong><%= r.combo_name %></strong><% } %>
      </span>
      <span style="background:#fef3c7;color:#92400e;padding:.15rem .6rem;border-radius:100px;font-size:.75rem;font-weight:600">Pending</span>
    </div>
  <% }) %>
</div>
<% } %>

<% if (combinations.length === 0) { %>
  <div class="admin-empty">
    <div class="empty-icon">📚</div>
    <h3>No combinations yet</h3>
    <p><%= typeof isSuper !== 'undefined' && !isSuper ? 'Submit a request to add a combination.' : 'Add combinations like MPC, PCB, SOD, CSA…' %></p>
    <a href="/admin/levels/<%= level.id %>/combinations/create" class="btn-primary">
      <%= typeof isSuper !== 'undefined' && !isSuper ? '+ Request First Combination' : '+ Add First Combination' %>
    </a>
  </div>
<% } else { %>
  <div class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr><th>Combination</th><th>Description</th><th>Classes</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% combinations.forEach(combo => { %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:.75rem">
                <div style="width:36px;height:36px;border-radius:10px;background:<%= combo.color %>22;border:2px solid <%= combo.color %>;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.8rem;color:<%= combo.color %>">
                  <%= combo.name.substring(0,3) %>
                </div>
                <div>
                  <strong><%= combo.name %></strong>
                </div>
              </div>
            </td>
            <td style="color:var(--muted);font-size:.875rem;max-width:300px"><%= combo.description || '—' %></td>
            <td>
              <a href="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>/classes" style="display:inline-flex;align-items:center;gap:.3rem;color:var(--primary);font-weight:600;font-size:.875rem">
                🏫 View Classes →
              </a>
            </td>
            <td>
              <div style="display:flex;gap:.5rem">
                <a href="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>/edit" class="btn-sm btn-edit">
                  <%= typeof isSuper !== 'undefined' && !isSuper ? '✏️ Request Edit' : '✏️ Edit' %>
                </a>
                <% if (typeof isSuper !== 'undefined' && isSuper) { %>
                <form action="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>/delete" method="POST" onsubmit="return confirm('Delete <%= combo.name %> and all content?')">
                  <button type="submit" class="btn-sm btn-delete">🗑 Delete</button>
                </form>
                <% } else { %>
                <form action="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>/delete" method="POST" onsubmit="return confirm('Submit delete request for <%= combo.name %>?')">
                  <button type="submit" class="btn-sm btn-delete">🗑 Request Delete</button>
                </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<style>
.info-box { background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:1rem 1.25rem; }
.admin-table-wrap { background:white;border-radius:12px;border:1px solid var(--border);overflow:hidden; }
.admin-table { width:100%;border-collapse:collapse; }
.admin-table th { background:#f8f7ff;padding:.85rem 1.25rem;text-align:left;font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);border-bottom:1px solid var(--border); }
.admin-table td { padding:1rem 1.25rem;border-bottom:1px solid #f1f0f8;font-size:.9rem;vertical-align:middle; }
.admin-table tr:last-child td { border-bottom:none; }
.admin-table tr:hover td { background:#fafafe; }
.btn-sm { padding:.3rem .75rem;border-radius:6px;font-size:.8rem;font-weight:600;cursor:pointer;border:none;text-decoration:none;display:inline-block; }
.btn-edit { background:#ede9fe;color:#4f46e5; }
.btn-delete { background:#fee2e2;color:#dc2626; }
</style>
