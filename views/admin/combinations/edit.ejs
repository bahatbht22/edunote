<div class="admin-page-header">
  <div>
    <h1>Edit Combination</h1>
    <div class="admin-breadcrumb">
      <a href="<%= typeof session !== 'undefined' && session.adminRole === 'sub' ? '/admin/levels/' + session.adminLevelId + '/combinations' : '/admin/levels' %>">Levels</a> ›
      <a href="/admin/levels/<%= level.id %>/combinations"><%= level.name %></a> ›
      Edit
    </div>
  </div>
</div>
<div class="card" style="max-width:700px">
  <div class="card-body">
    <form action="/admin/levels/<%= level.id %>/combinations/<%= combo.id %>" method="POST">
      <div class="form-grid">
        <div class="form-group full">
          <label>Name <span class="req">*</span></label>
          <input type="text" name="name" value="<%= combo.name %>" required>
        </div>
        <div class="form-group full">
          <label>Description</label>
          <textarea name="description"><%= combo.description %></textarea>
        </div>
        <div class="form-group">
          <label>Color</label>
          <input type="color" name="color" value="<%= combo.color %>">
        </div>
        <div class="form-group">
          <label>Display Order</label>
          <input type="number" name="order_index" value="<%= combo.order_index %>">
        </div>
      </div>
      <div style="display:flex;gap:1rem;margin-top:1.5rem">
        <button type="submit" class="btn btn-primary btn-lg"><%= typeof isSuper !== "undefined" && isSuper ? "Save Changes" : "Submit Edit Request" %></button>
        <a href="/admin/levels/<%= level.id %>/combinations" class="btn btn-secondary btn-lg">Cancel</a>
      </div>
    </form>
  </div>
</div>
