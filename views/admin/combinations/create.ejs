<div class="admin-page-header">
  <div>
    <h1><%= typeof isSuper !== "undefined" && isSuper ? "Add Combination" : "Request New Combination" %></h1>
    <div class="admin-breadcrumb">
      <a href="<%= typeof session !== 'undefined' && session.adminRole === 'sub' ? '/admin/levels/' + session.adminLevelId + '/combinations' : '/admin/levels' %>">Levels</a> ›
      <a href="/admin/levels/<%= level.id %>/combinations"><%= level.name %></a> ›
      Add
    </div>
  </div>
</div>
<div class="card" style="max-width:700px">
  <div class="card-body">
    <form action="/admin/levels/<%= level.id %>/combinations" method="POST">
      <div class="form-grid">
        <div class="form-group full">
          <label>Name <span class="req">*</span></label>
          <input type="text" name="name" placeholder="e.g. MPC, PCB, SOD, Computer Science" required>
          <span class="form-hint">Short code or full name e.g. MPC, Physics-Chemistry-Biology</span>
        </div>
        <div class="form-group full">
          <label>Description</label>
          <textarea name="description" placeholder="Brief description of this combination..."></textarea>
        </div>
        <div class="form-group">
          <label>Color</label>
          <input type="color" name="color" value="#6366f1">
        </div>
        <div class="form-group">
          <label>Display Order</label>
          <input type="number" name="order_index" value="0" min="0">
        </div>
      </div>
      <div style="display:flex;gap:1rem;margin-top:1.5rem">
        <button type="submit" class="btn btn-primary btn-lg"><%= typeof isSuper !== "undefined" && isSuper ? "Create Combination" : "Submit Request" %></button>
        <a href="/admin/levels/<%= level.id %>/combinations" class="btn btn-secondary btn-lg">Cancel</a>
      </div>
    </form>
  </div>
</div>
