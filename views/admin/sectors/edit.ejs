<div class="admin-page">
  <div class="page-title-row">
    <div>
      <a href="/admin/sectors" class="back-link-admin">← Back to Sectors</a>
      <h2>Edit Sector</h2>
    </div>
  </div>
  <div class="form-card">
    <form action="/admin/sectors/<%= sector.id %>/update" method="POST">
      <div class="form-grid">
        <div class="form-group">
          <label for="name">Sector Name <span class="required">*</span></label>
          <input type="text" id="name" name="name" value="<%= sector.name %>" required maxlength="150">
        </div>
        <div class="form-group">
          <label for="color">Color</label>
          <div class="color-input-wrap">
            <input type="color" id="color" name="color" value="<%= sector.color %>" class="color-picker">
            <input type="text" id="colorText" value="<%= sector.color %>" class="color-text" maxlength="7">
          </div>
        </div>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3" maxlength="500"><%= sector.description || '' %></textarea>
      </div>
      <div class="form-actions">
        <a href="/admin/sectors" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>
<script>
document.getElementById('color').addEventListener('input', function() { document.getElementById('colorText').value = this.value; });
document.getElementById('colorText').addEventListener('input', function() { if(/^#[0-9A-Fa-f]{6}$/.test(this.value)) document.getElementById('color').value = this.value; });
</script>
