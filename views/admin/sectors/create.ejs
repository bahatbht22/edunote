<div class="admin-page">
  <div class="page-title-row">
    <div>
      <a href="/admin/sectors" class="back-link-admin">← Back to Sectors</a>
      <h2>Create New Sector</h2>
    </div>
  </div>
  <div class="form-card">
    <form action="/admin/sectors" method="POST">
      <div class="form-grid">
        <div class="form-group">
          <label for="name">Sector Name <span class="required">*</span></label>
          <input type="text" id="name" name="name" placeholder="e.g. Mathematics" required maxlength="150">
          <small class="form-hint">After creating, you can add education levels inside this sector.</small>
        </div>
        <div class="form-group">
          <label for="color">Color</label>
          <div class="color-input-wrap">
            <input type="color" id="color" name="color" value="#6366f1" class="color-picker">
            <input type="text" id="colorText" value="#6366f1" class="color-text" maxlength="7">
          </div>
        </div>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="3" placeholder="Brief description of this subject..." maxlength="500"></textarea>
      </div>
      <div class="form-actions">
        <a href="/admin/sectors" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Create Sector</button>
      </div>
    </form>
  </div>
</div>
<script>
document.getElementById('color').addEventListener('input', function() { document.getElementById('colorText').value = this.value; });
document.getElementById('colorText').addEventListener('input', function() { if(/^#[0-9A-Fa-f]{6}$/.test(this.value)) document.getElementById('color').value = this.value; });
</script>
