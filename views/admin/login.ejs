<div class="auth-card">
  <div class="auth-logo">📚 Edu<span>Note</span></div>
  <p class="auth-subtitle">Sign in to manage content</p>

  <% if (locals.error && error.length > 0) { %>
    <div class="flash flash-error" style="margin-bottom:1.5rem">⚠ <%= error[0] %></div>
  <% } %>

  <form action="/admin/login" method="POST">
    <div class="form-group" style="margin-bottom:1.25rem">
      <label for="email">Email Address</label>
      <input type="email" id="email" name="email" placeholder="admin@edunote.com" required autocomplete="email">
    </div>
    <div class="form-group" style="margin-bottom:1.75rem">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password">
    </div>
    <button type="submit" class="btn btn-primary btn-lg" style="width:100%;justify-content:center">Sign In →</button>
  </form>

  <div style="text-align:center;margin-top:1.5rem">
    <a href="/" style="font-size:.875rem;color:var(--muted)">← Back to site</a>
  </div>
</div>
