<div class="admin-page-header">
  <div>
    <h1 class="admin-page-title">Edit Sub-Admin</h1>
    <p class="admin-page-sub">Update details for <%= subAdmin.name %></p>
  </div>
  <a href="/admin/subadmins" class="btn-outline">← Back</a>
</div>

<% const msgs = typeof messages !== 'undefined' ? messages : {}; %>
<% if (msgs.error && msgs.error.length) { %><div class="alert alert-error"><%= msgs.error[0] %></div><% } %>

<div class="admin-form-card">
  <form action="/admin/subadmins/<%= subAdmin.id %>" method="POST">
    <div class="form-group">
      <label>Full Name</label>
      <input type="text" name="name" class="form-input" value="<%= subAdmin.name %>" required>
    </div>
    <div class="form-group">
      <label>Email Address</label>
      <input type="email" name="email" class="form-input" value="<%= subAdmin.email %>" required>
    </div>
    <div class="form-group">
      <label>Assigned Level</label>
      <select name="level_id" class="form-input" required>
        <option value="">— Select a level —</option>
        <% levels.forEach(l => { %>
          <option value="<%= l.id %>" <%= subAdmin.level_id == l.id ? 'selected' : '' %>><%= l.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-group">
      <label>New Password <small style="color:var(--muted);font-weight:400">(leave blank to keep current)</small></label>
      <input type="password" name="new_password" class="form-input" placeholder="Enter new password to change it" minlength="6">
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-primary">Save Changes</button>
      <a href="/admin/subadmins" class="btn-outline">Cancel</a>
    </div>
  </form>
</div>
