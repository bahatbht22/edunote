<div class="admin-page-header">
  <div>
    <h1 class="admin-page-title">Add Sub-Admin</h1>
    <p class="admin-page-sub">Assign an admin to a specific education level</p>
  </div>
  <a href="/admin/subadmins" class="btn-outline">← Back</a>
</div>

<% const msgs = typeof messages !== 'undefined' ? messages : {}; %>
<% if (msgs.error && msgs.error.length) { %><div class="alert alert-error"><%= msgs.error[0] %></div><% } %>

<div class="admin-form-card">
  <form action="/admin/subadmins" method="POST">
    <div class="form-group">
      <label>Full Name</label>
      <input type="text" name="name" class="form-input" placeholder="e.g. John Doe" required>
    </div>
    <div class="form-group">
      <label>Email Address</label>
      <input type="email" name="email" class="form-input" placeholder="admin@example.com" required>
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" class="form-input" placeholder="Min 6 characters" minlength="6" required>
    </div>
    <div class="form-group">
      <label>Assigned Level</label>
      <select name="level_id" class="form-input" required>
        <option value="">— Select a level —</option>
        <% levels.forEach(l => { %>
          <option value="<%= l.id %>"><%= l.name %></option>
        <% }) %>
      </select>
      <small class="form-hint">This admin will only be able to manage content under this level.</small>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-primary">Create Sub-Admin</button>
      <a href="/admin/subadmins" class="btn-outline">Cancel</a>
    </div>
  </form>
</div>
